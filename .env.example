# ── Azure Blob Storage ──────────────────────────────────────────────────────
# Required. Full connection string from Azure Portal > Storage Account > Access keys.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net

# ── Azure AI Search ─────────────────────────────────────────────────────────
# Required. Endpoint and admin key from Azure Portal > AI Search > Keys.
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_KEY=<your-admin-key>

# ── Azure OpenAI (embeddings + SK team leader) ───────────────────────────────
# Required. Used for text-embedding-ada-002 embeddings and the SK kernel LLM.
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_KEY=<your-openai-key>
# Optional — default: gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Azure AI Foundry (LLM validator in FormattingEngineAgent) ────────────────
# Required. Endpoint and key from Azure AI Foundry project > Settings.
AZURE_FOUNDRY_ENDPOINT=https://<your-project>.cognitiveservices.azure.com
AZURE_FOUNDRY_KEY=<your-foundry-key>
# Optional — default: gpt-4o-mini
AZURE_FOUNDRY_DEPLOYMENT=gpt-4o-mini

# ── LLM Backend Selection ────────────────────────────────────────────────────
# Controls the primary LLM backend. Options: "foundry" (default) | "github" | "ollama" | "azure"
LLM_BACKEND=foundry

# Foundry model — default: Phi-3.5-mini-instruct
AZURE_FOUNDRY_DEPLOYMENT=Phi-3.5-mini-instruct

# GitHub Models primary backend — only used when LLM_BACKEND=github (requires GITHUB_TOKEN)
GITHUB_MODELS_MODEL=Phi-3.5-mini-instruct

# GitHub Models 429 fallback model (applies to all backends)
# Default: Phi-3.5-mini-instruct  (set to Phi-3-mini-128k-instruct for the smaller/faster variant)
GITHUB_FALLBACK_MODEL=Phi-3.5-mini-instruct

# Ollama (local inference) — only used when LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=phi4

# ── Microsoft Graph API (OneDrive sharing links) ─────────────────────────────
# Required. Register an app in Entra ID (Azure AD) with Files.ReadWrite.All permission.
GRAPH_TENANT_ID=<your-tenant-id>
GRAPH_CLIENT_ID=<your-client-id>
GRAPH_CLIENT_SECRET=<your-client-secret>

# ── Teams Bot ────────────────────────────────────────────────────────────────
# Required. Values from Azure Bot resource > Configuration > Microsoft App ID/Password.
MICROSOFT_APP_ID=<your-bot-app-id>
MICROSOFT_APP_PASSWORD=<your-bot-password>
# Optional — default: 3978
PORT=3978

# ── Azure Blob Container Names ───────────────────────────────────────────────
# Optional — change only if your infrastructure uses different container names.
# Defaults match the names provisioned by the project's ARM/Bicep templates.
BLOB_CONTAINER_INPUT=examops-input
BLOB_CONTAINER_OUTPUT=examops-output
BLOB_CONTAINER_TEMPLATES=examops-templates

# ── Azure AI Search Index Name ───────────────────────────────────────────────
# Optional — default: exam-templates
SEARCH_INDEX_NAME=exam-templates

# ── Embedding Model ──────────────────────────────────────────────────────────
# Optional — default: text-embedding-ada-002
AZURE_EMBEDDING_MODEL=text-embedding-ada-002
