{
  "$schema": "http://json.schemastore.org/proxies",
  "proxies": {
    "rootToWeb": {
      "matchCondition": {
        "methods": ["GET"],
        "route": "/"
      },
      "responseOverrides": {
        "response.statusCode": "302",
        "response.headers.Location": "/api/web"
      }
    }
  }
}
